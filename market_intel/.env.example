# ═══════════════════════════════════════════════════════════════════════════════
# MARKET INTELLIGENCE ENGINE - ENVIRONMENT CONFIGURATION
# ═══════════════════════════════════════════════════════════════════════════════
# 
# FREE PUBLIC APIs BUILT-IN (NO KEY NEEDED):
# - SEC EDGAR: Insider filings
# - Yahoo Finance: Stock prices, VIX
# - CoinGecko: Crypto prices
# - DeFiLlama: DeFi TVL data
# - Alternative.me: Crypto Fear & Greed
# - ApeWisdom/Reddit: Social sentiment
# - StockTwits: Trading sentiment
# - Blockchair: BTC transactions
#
# MINIMUM SETUP: Just Telegram OR Discord (free)
# RECOMMENDED: Add Finnhub + Etherscan (both free)

# ─────────────────────────────────────────────────────────────────────────────────
# 💰 OPENAI (Optional - ~$1-3/mo - improves sentiment analysis)
# Leave blank to use FREE rule-based sentiment fallback
# ─────────────────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────────
# 🆓 FINNHUB (Free tier - 60 calls/min - Stock data & news)
# Get your FREE key at: https://finnhub.io/
# ─────────────────────────────────────────────────────────────────────────────────
FINNHUB_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────────
# 🆓 WHALE ALERT (Free tier works - 10 calls/min)
# Get FREE key at: https://whale-alert.io/
# ─────────────────────────────────────────────────────────────────────────────────
WHALE_ALERT_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────────
# 💰 UNUSUAL WHALES (SKIP - $40+/mo - Finnhub covers options flow for free)
# ─────────────────────────────────────────────────────────────────────────────────
UNUSUAL_WHALES_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────────
# 💰 TWITTER/X API (SKIP - Expensive - using free Reddit/StockTwits instead)
# ─────────────────────────────────────────────────────────────────────────────────
TWITTER_BEARER_TOKEN=

# ─────────────────────────────────────────────────────────────────────────────────
# 🆓 ADVANCED DATA SOURCES (All have free tiers - optional)
# ─────────────────────────────────────────────────────────────────────────────────

# QuiverQuant - Congressional trades (free tier limited but works)
QUIVER_QUANT_API_KEY=

# Etherscan - On-chain Ethereum data (FREE - 5 calls/sec)
ETHERSCAN_API_KEY=

# Financial Modeling Prep (FREE tier - 250 calls/day)
FMP_API_KEY=

# Polygon.io (FREE tier - 5 calls/min)
POLYGON_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────────
# 🆓 ALERT DELIVERY - DISCORD (Required - Pick Discord OR Telegram)
# Create webhook: Server Settings → Integrations → Webhooks → New Webhook
# ─────────────────────────────────────────────────────────────────────────────────
DISCORD_WEBHOOK_URL=

# ─────────────────────────────────────────────────────────────────────────────────
# 🆓 ALERT DELIVERY - TELEGRAM (Alternative to Discord)
# Create bot via @BotFather, get chat_id via @userinfobot
# ─────────────────────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─────────────────────────────────────────────────────────────────────────────────
# DATABASE (SQLite by default, PostgreSQL for cloud)
# ─────────────────────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///data/signals.db
# For PostgreSQL: DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ─────────────────────────────────────────────────────────────────────────────────
# SYSTEM SETTINGS
# ─────────────────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
ALERT_COOLDOWN_HOURS=24
MIN_SIGNAL_SCORE=60
HIGH_CONFIDENCE_THRESHOLD=80
